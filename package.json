{
  "name": "openkanban",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "workspaces": [
    "packages/core",
    "packages/plugin",
    "packages/sidecar",
    "packages/desktop"
  ],
  "scripts": {
    "build": "npm run build:core && npm run build:plugin",
    "bundle:plugin": "node scripts/bundle-plugin.mjs",
    "build:core": "npm run build -w @openkanban/core",
    "build:plugin": "npm run build -w @openkanban/plugin",
    "build:sidecar": "npm run build -w packages/sidecar",
    "build:sidecar-bundle": "npx esbuild packages/sidecar/src/bundle-entry.ts --bundle --platform=node --format=cjs --outfile=packages/sidecar/dist/sidecar-bundle.cjs",
    "build:desktop": "npm run build -w packages/desktop",
    "dev:desktop": "npm run dev -w packages/desktop",
    "build:all": "npm run build:core && npm run build:sidecar && npm run build:sidecar-bundle && npm run build:desktop",
    "test": "vitest run",
    "typecheck": "tsc -b"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "esbuild": "^0.28.0",
    "happy-dom": "^20.8.8",
    "typescript": "^6.0.2",
    "vitest": "^4.1.1"
  }
}
