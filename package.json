{
  "name": "neon-tiger",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "workspaces": [
    "packages/core",
    "packages/plugin",
    "packages/sidecar",
    "packages/desktop"
  ],
  "scripts": {
    "build": "npm run build:core && npm run build:plugin",
    "build:core": "npm run build -w @neon-tiger/core",
    "build:plugin": "npm run build -w @neon-tiger/plugin",
    "build:sidecar": "npm run build -w packages/sidecar",
    "build:desktop": "npm run build -w packages/desktop",
    "dev:desktop": "npm run dev -w packages/desktop",
    "build:all": "npm run build:core && npm run build:sidecar && npm run build:desktop",
    "test": "vitest run",
    "typecheck": "tsc -b"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "happy-dom": "^20.8.8",
    "typescript": "^6.0.2",
    "vitest": "^4.1.1"
  }
}
